<mxfile host="app.diagrams.net" type="device">
  <diagram id="ecommerce-arch" name="01_architecture">
    <mxGraphModel dx="1100" dy="780" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="740" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b style='font-size:18px;color:#263238'&gt;파일 기반 e-Commerce · 계층형 아키텍처&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="60" y="22" width="880" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="&lt;span style='color:#6B7785;font-size:12px'&gt;JSON 파일을 DB처럼 사용하는 콘솔 애플리케이션 — controller → service → repository → JsonUtil → JSON 파일&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="54" width="880" height="20" as="geometry" />
        </mxCell>

        <mxCell id="main" value="&lt;b style='font-size:13px;color:#37474F'&gt;Ecommerce.main()&lt;/b&gt;&lt;br&gt;&lt;span style='color:#6B7785;font-size:11px'&gt;JsonUtil로 JSON 6종 로드 → UserController.showGuestMenu()&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#37474F;strokeWidth=2;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="92" width="510" height="48" as="geometry" />
        </mxCell>

        <mxCell id="ctrl" value="&lt;b style='color:#1565C0;font-size:14px'&gt;controller&lt;/b&gt; &lt;span style='color:#6B7785;font-size:11px'&gt;— 콘솔 메뉴 · 입력 처리&lt;/span&gt;&lt;div style='font-family:Courier New;font-size:11px;color:#37474F;margin-top:6px'&gt;UserController · ProductController · CartController&lt;br&gt;OrderController · CategoryController · UserProductController&lt;br&gt;AdminUserController · AdminOrderController · ProductCategoryMappingController&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;strokeWidth=3;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="168" width="510" height="86" as="geometry" />
        </mxCell>

        <mxCell id="svc" value="&lt;b style='color:#D05C17;font-size:14px'&gt;service&lt;/b&gt; &lt;span style='color:#6B7785;font-size:11px'&gt;— 비즈니스 로직 · 검증 · 재고/상태 처리&lt;/span&gt;&lt;div style='font-family:Courier New;font-size:11px;color:#37474F;margin-top:6px'&gt;UserService · OrderService · CartService · ProductService&lt;br&gt;CategoryService · UserProductService · ProductCategoryMappingService&lt;br&gt;AdminUserService · AdminOrderService&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D05C17;strokeWidth=3;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
