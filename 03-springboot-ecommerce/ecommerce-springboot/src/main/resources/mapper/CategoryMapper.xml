<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.shop.repository.mapper.CategoryMapper">

    <resultMap id="CategoryResponseMap"
               type="kr.co.shop.dto.category.response.CategoryResponse">
        <constructor>
            <arg column="nbCategory" javaType="java.lang.Long"/>
            <arg column="nbParentCategory" javaType="java.lang.Long"/>
            <arg column="nmCategory" javaType="java.lang.String"/>
            <arg column="cnLevel" javaType="java.lang.Integer"/>
            <arg column="cnOrder" javaType="java.lang.Integer"/>
        </constructor>
    </resultMap>

    <select id="findAllCategories" resultMap="CategoryResponseMap">
        SELECT
        c.nb_category AS nbCategory,
        c.nb_parent_category AS nbParentCategory,
        c.nm_category AS nmCategory,
        c.cn_level AS cnLevel,
        c.cn_order AS cnOrder
        FROM tb_category c
        ORDER BY c.cn_level ASC, c.cn_order ASC
    </select>

</mapper>